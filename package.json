{
    "devDependencies": {
        "@types/chrome": "^0.0.303",
        "@types/node": "^22.0.0",
        "esbuild": "^0.25.0",
        "jest": "^30.4.2",
        "msw": "^2.14.6",
        "prettier": "3.8.3",
        "prettier-plugin-organize-imports": "4.1.0",
        "puppeteer": "^25.1.0",
        "ts-jest": "^29.4.0",
        "typescript": "^5.7.0",
        "web-ext": "^10.4.0"
    },
    "type": "module",
    "scripts": {
        "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/src/test/**/*.test.ts"
        ],
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "transform": {
            "^.+\\.ts$": [
                "ts-jest",
                {
                    "useESM": true
                }
            ]
        }
    },
    "dependencies": {
        "ts-pattern": "^5.9.0"
    }
}
